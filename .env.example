# URL do projeto Supabase
SUPABASE_URL=https://rixzxbsareoyfvjmeavu.supabase.co

# Chave anon (Settings → API → Project API keys → anon public)
# Usada no navegador para leitura da tabela membros (com RLS adequada).
SUPABASE_ANON_KEY=

# Chave service_role — APENAS no servidor (Railway). Nunca no frontend.
# Usada para Storage, inserção em solicitacoes e checagem de pendência.
SUPABASE_SERVICE_ROLE_KEY=

# Porta local (Railway define PORT automaticamente)
PORT=3000

# Painel /admin — escolha UM dos modos:
#
# (A) Login com utilizador + senha (recomendado): defina hash SHA-256 da senha em hex (64 caracteres).
#     Gere com: node -e "console.log(require('crypto').createHash('sha256').update('SUA_SENHA','utf8').digest('hex'))"
#     ADMIN_SECRET continua obrigatório: assina o JWT de sessão (não é a senha em claro).
#     Para múltiplos utilizadores (mais simples no Railway), use:
#     ADMIN_CREDENTIALS=admin:hash_sha256;secretaria:hash_sha256;outro:hash_sha256
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_SHA256=
#
# (B) Só token: deixe ADMIN_PASSWORD_SHA256 vazio e use apenas ADMIN_SECRET como "token" no painel.
ADMIN_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD_SHA256=
ADMIN_CREDENTIALS=

# URL pública do site (opcional) — QR no verso da carteira (ex.: https://xxx.railway.app)
PUBLIC_SITE_URL=

# Embed em iframe (site principal):
# - false (padrão): bloqueia embed (X-Frame-Options: DENY + CSP frame-ancestors 'none')
# - true: permite embed APENAS nos domínios listados em ALLOWED_FRAME_ANCESTORS
ALLOW_IFRAME=false
# Separar múltiplos domínios por espaço:
# ALLOWED_FRAME_ANCESTORS=https://SEU_DOMINIO.com https://www.SEU_DOMINIO.com
ALLOWED_FRAME_ANCESTORS=
